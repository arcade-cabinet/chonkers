{
	"name": "chonkers",
	"version": "0.0.0",
	"private": true,
	"description": "Chonkers — checkers, but you stack instead of capture",
	"type": "module",
	"packageManager": "pnpm@10.33.0",
	"keywords": [
		"capacitor",
		"mobile",
		"r3f",
		"three",
		"game",
		"chonkers"
	],
	"scripts": {
		"dev": "vite",
		"start": "vite",
		"build": "tsc --noEmit && vite build",
		"build:native": "tsc --noEmit && cross-env CAPACITOR=true vite build",
		"preview": "vite preview",
		"typecheck": "tsc --noEmit",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write .",
		"test": "vitest run --passWithNoTests",
		"test:node": "vitest run --project node --passWithNoTests",
		"test:browser": "vitest run --project browser --passWithNoTests",
		"test:watch": "vitest",
		"test:e2e": "playwright test",
		"test:e2e:ci": "test -d e2e && playwright test --grep-invert @nightly || echo 'no e2e specs yet — skipping'",
		"test:e2e:nightly": "test -d e2e && playwright test --grep @nightly || echo 'no e2e specs yet — skipping'",
		"copywasm": "node scripts/copy-wasm.mjs",
		"predev": "pnpm copywasm",
		"prebuild": "pnpm copywasm",
		"prebuild:native": "pnpm copywasm",
		"prepreview": "pnpm copywasm",
		"pretest:browser": "pnpm copywasm",
		"pretest:e2e": "pnpm copywasm",
		"pretest:e2e:ci": "pnpm copywasm",
		"cap:sync": "pnpm build:native && cap sync",
		"native:android:debug": "pnpm build:native && cap sync android && cd android && ./gradlew assembleDebug",
		"native:ios:build": "pnpm build:native && cap sync ios && xcodebuild -project ios/App/App.xcodeproj -scheme App -configuration Debug -sdk iphonesimulator -destination 'platform=iOS Simulator,name=iPhone 16'"
	},
	"dependencies": {
		"@capacitor-community/sqlite": "^8.1.0",
		"@capacitor/android": "^8.3.1",
		"@capacitor/app": "^8.1.0",
		"@capacitor/core": "^8.3.1",
		"@capacitor/haptics": "^8.0.2",
		"@capacitor/ios": "^8.3.1",
		"@capacitor/preferences": "^8.0.1",
		"@capacitor/screen-orientation": "^8.0.1",
		"@capacitor/splash-screen": "^8.0.1",
		"@radix-ui/themes": "^3.3.0",
		"@react-three/drei": "^10.7.7",
		"@react-three/fiber": "^9.6.1",
		"framer-motion": "^12.23.0",
		"jeep-sqlite": "^2.8.0",
		"react": "^19.2.5",
		"react-dom": "^19.2.5",
		"sql.js": "1.11.0",
		"three": "^0.184.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.13",
		"@capacitor/cli": "^8.3.1",
		"@playwright/test": "^1.59.1",
		"@types/node": "^25.6.0",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@types/sql.js": "^1.4.11",
		"@types/three": "^0.184.0",
		"@vitejs/plugin-react": "^6.0.1",
		"@vitest/browser": "^4.1.5",
		"@vitest/browser-playwright": "^4.1.5",
		"cross-env": "^10.1.0",
		"fast-check": "^4.7.0",
		"playwright": "^1.59.1",
		"typescript": "^6.0.3",
		"vite": "^8.0.10",
		"vitest": "^4.1.5"
	},
	"author": "arcade-cabinet",
	"license": "MIT"
}
