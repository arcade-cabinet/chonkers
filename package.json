{
	"name": "chonkers",
	"version": "0.0.0",
	"private": true,
	"description": "Chonkers — checkers, but you stack instead of capture",
	"type": "module",
	"packageManager": "pnpm@10.33.0",
	"keywords": [
		"capacitor",
		"mobile",
		"three",
		"gsap",
		"game",
		"chonkers"
	],
	"scripts": {
		"dev": "vite",
		"start": "vite",
		"build": "tsc --noEmit && vite build",
		"build:native": "tsc --noEmit && cross-env CAPACITOR=true vite build",
		"preview": "vite preview",
		"typecheck": "tsc --noEmit",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write .",
		"test": "vitest run --project node --project browser --passWithNoTests",
		"test:node": "vitest run --project node --passWithNoTests",
		"test:browser": "vitest run --project browser --passWithNoTests",
		"test:alpha": "vitest run --project alpha --passWithNoTests",
		"test:watch": "vitest",
		"test:e2e": "playwright test",
		"test:e2e:ci": "test -d e2e && playwright test --grep-invert '@nightly|@governor' || echo 'no e2e specs yet — skipping'",
		"test:e2e:nightly": "test -d e2e && playwright test --grep @nightly || echo 'no e2e specs yet — skipping'",
		"test:e2e:governor": "test -d e2e && playwright test --grep @governor || echo 'no e2e specs yet — skipping'",
		"cap:sync": "pnpm build:native && cap sync",
		"native:android:debug": "pnpm build:native && cap sync android && cd android && ./gradlew assembleDebug",
		"native:ios:build": "pnpm build:native && cap sync ios && xcodebuild -project ios/App/App.xcodeproj -scheme App -configuration Debug -sdk iphonesimulator -destination 'platform=iOS Simulator,name=iPhone 16'"
	},
	"dependencies": {
		"@capacitor/android": "^8.3.1",
		"@capacitor/app": "^8.1.0",
		"@capacitor/core": "^8.3.1",
		"@capacitor/haptics": "^8.0.2",
		"@capacitor/ios": "^8.3.1",
		"@capacitor/preferences": "^8.0.1",
		"@capacitor/screen-orientation": "^8.0.1",
		"@capacitor/splash-screen": "^8.0.1",
		"@capacitor/status-bar": "^8.0.2",
		"@types/howler": "^2.2.12",
		"gsap": "^3.15.0",
		"howler": "^2.2.4",
		"koota": "^0.6.6",
		"three": "^0.184.0",
		"yuka": "^0.7.8"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.13",
		"@capacitor/cli": "^8.3.1",
		"@playwright/test": "^1.59.1",
		"@types/node": "^25.6.0",
		"@types/three": "^0.184.0",
		"@types/yuka": "^0.7.4",
		"@vitest/browser": "^4.1.5",
		"@vitest/browser-playwright": "^4.1.5",
		"cross-env": "^10.1.0",
		"fast-check": "^4.7.0",
		"playwright": "^1.59.1",
		"typescript": "^6.0.3",
		"vite": "^8.0.10",
		"vitest": "^4.1.5"
	},
	"author": "arcade-cabinet",
	"license": "MIT"
}
